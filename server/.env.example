PORT=4000
API_VERSION=1

# Option 1: explicit fields
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=accounting_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Optional connection pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Option 2: use a single connection string instead of DB_HOST/DB_PORT/...
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/accounting_system

# Frontend (client) can point Vite proxy here
# VITE_API_TARGET=http://127.0.0.1:4000
